# 정보시스템 NAS 설정
NAS_HOST_1=192.168.x.x
NAS_SHARE_1=share_name
NAS_USERNAME_1=domain\username
NAS_PASSWORD_1=password
NAS_NAME_1=Main NAS

# 추가 NAS (선택사항)
NAS_HOST_2=192.168.x.x
NAS_SHARE_2=share_name
NAS_USERNAME_2=username
NAS_PASSWORD_2=password
NAS_NAME_2=Backup NAS

# Elasticsearch 설정
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme
ELASTICSEARCH_INDEX_NAME=nas_files
ELASTICSEARCH_USE_SSL=true

# 크롤러 설정
CRAWLER_BATCH_SIZE=100
CRAWLER_THREAD_COUNT=4
CRAWLER_TIMEOUT=30
CRAWLER_RETRY_COUNT=3
CRAWLER_UPDATE_INTERVAL=86400

# 로깅 설정
LOG_LEVEL=INFO
LOG_FILE=logs/nas_search.log

# MCP 서버 설정
MCP_HOST=localhost
MCP_PORT=8000

# 애플리케이션
ENVIRONMENT=development
DEBUG=false
